#!/usr/bin/env php
<?php

declare(strict_types=1);

(static function () {
    foreach (['vendor/autoload.php', __DIR__ . '/../vendor/autoload.php', __DIR__ . '/../../../autoload.php'] as $candidate) {
        $path = str_starts_with($candidate, '/') ? $candidate : __DIR__ . '/../' . $candidate;
        if (is_file($path)) {
            require $path;
            return;
        }
    }
    fwrite(STDERR, "candy-flip: cannot find composer autoload.php\n");
    exit(1);
})();

use SugarCraft\Core\Program;
use SugarCraft\Core\ProgramOptions;
use SugarCraft\Flip\Decoder;
use SugarCraft\Flip\Lang;
use SugarCraft\Flip\Player;
use SugarCraft\Flip\Renderer;
use SugarCraft\Pty\SizeIoctl;

$argv = $argv ?? [];
$path  = $argv[1] ?? null;
$preset = ($argv[2] ?? '') === 'density' ? Renderer::PRESET_DENSITY : Renderer::PRESET_SOLID;
if ($path === null) {
    fwrite(STDERR, Lang::t('cli.usage') . "\n");
    exit(1);
}

// Size the decode grid to the terminal viewport (cols, rows-1 for status line).
// Fall back to 60x24 when not running in a TTY (e.g. piped/CI).
if (posix_isatty(STDOUT)) {
    $size = SizeIoctl::query((int) STDOUT);
    $cellsW = $size['cols'];
    $cellsH = max(1, $size['rows'] - 1); // reserve 1 row for the status line
} else {
    $cellsW = 60;
    $cellsH = 24;
}

$frames = Decoder::decode($path, cellsW: $cellsW, cellsH: $cellsH);
$renderer = Renderer::withConstraints($cellsH, $cellsW);
$player = new Player($frames, preset: $preset, renderer: $renderer);

(new Program($player, new ProgramOptions(useAltScreen: true)))->run();
